{
  "name": "filmisbest",
  "version": "1.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "prisma:generate": "prisma generate",
    "prisma:dbpush": "prisma db push",
    "check": "node scripts/pr-checks.ts",
    "react-doctor": "react-doctor --verbose",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typegen": "sanity schema extract --enforce-required-fields  --path=./src/sanity/extract.json && sanity typegen generate && rm ./src/sanity/extract.json",
    "install:skills": "pnpx skills@latest experimental_install",
    "install:heroui_docs": "pnpx heroui-cli@latest agents-md --react --output AGENTS.md",
    "sync:omdb": "sanity exec scripts/sync-omdb.ts --with-user-token",
    "remove-assets": "sanity exec scripts/remove-unused-assets.ts --with-user-token",
    "remove-assets:preview": "sanity exec scripts/preview-unused-assets.ts --with-user-token",
    "bootstrap": "pnpm install && pnpm install:skills && pnpm install:heroui_docs"
  },
  "dependencies": {
    "@ai-sdk/react": "4.0.31",
    "@better-auth/prisma-adapter": "1.6.23",
    "@heroui/avatar": "2.2.26",
    "@heroui/button": "2.2.32",
    "@heroui/dropdown": "2.3.32",
    "@heroui/input": "2.4.33",
    "@heroui/modal": "2.2.29",
    "@heroui/pagination": "2.2.27",
    "@heroui/select": "2.4.33",
    "@heroui/snippet": "2.2.33",
    "@heroui/system": "2.4.28",
    "@heroui/theme": "2.4.26",
    "@heroui/toast": "2.0.22",
    "@lottiefiles/dotlottie-react": "0.19.9",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@next/third-parties": "16.2.10",
    "@openrouter/ai-sdk-provider": "3.0.0",
    "@prisma/adapter-neon": "7.8.0",
    "@prisma/client": "7.8.0",
    "@sanity/client": "7.23.2",
    "@sanity/icons": "5.1.0",
    "@sanity/image-url": "2.1.1",
    "@sanity/ui": "3.3.5",
    "@sanity/vision": "6.5.0",
    "ai": "7.0.28",
    "better-auth": "1.6.23",
    "clsx": "2.1.1",
    "fuse.js": "7.5.0",
    "mcp-handler": "1.1.0",
