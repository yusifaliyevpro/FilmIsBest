    "next-intl": "4.13.2",
    "next-sanity": "13.1.3",
    "nuqs": "2.9.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "5.7.0",
    "sanity": "6.5.0",
    "server-only": "0.0.1",
    "styled-components": "6.4.3",
    "swiper": "14.0.5",
    "tailwind-merge": "3.6.0",
    "typescript": "6.0.3",
    "use-debounce": "10.1.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "24.12.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "17.4.2",
