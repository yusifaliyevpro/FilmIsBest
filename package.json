{
  "name": "filmisbest",
  "version": "1.5.0",
  "packageManager": "pnpm@11.9.0",
  "private": true,
  "scripts": {
    "bootstrap": "pnpm install && pnpm run install:skills && pnpm run install:heroui_docs",
    "dev": "next dev",
    "build": "prisma generate && next build",
    "prisma:generate": "prisma generate",
    "prisma:dbpush": "prisma db push",
    "checks": "node scripts/pr-checks.ts",
    "devbuild": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix",
    "install:skills": "pnpx skills@latest experimental_install",
    "install:heroui_docs": "pnpx heroui-cli@latest agents-md --react --output AGENTS.md",
    "typegen": "sanity schema extract --enforce-required-fields  --path=./src/sanity/extract.json && sanity typegen generate && rm ./src/sanity/extract.json",
    "doctor": "npx react-doctor@latest",
    "remove-assets": "npx sanity exec scripts/remove-unused-assets.ts --with-user-token",
    "remove-assets:preview": "npx sanity exec scripts/preview-unused-assets.ts --with-user-token"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "dependencies": {
    "@ai-sdk/react": "4.0.12",
    "@better-auth/prisma-adapter": "1.6.23",
    "@heroui/avatar": "2.2.26",
    "@heroui/button": "2.2.32",
    "@heroui/dropdown": "2.3.32",
    "@heroui/input": "2.4.33",
    "@heroui/modal": "2.2.29",
    "@heroui/navbar": "2.2.30",
    "@heroui/pagination": "2.2.27",
    "@heroui/select": "2.4.33",
    "@heroui/skeleton": "2.2.18",
    "@heroui/snippet": "2.2.33",
    "@heroui/system": "2.4.28",
    "@heroui/theme": "2.4.26",
    "@heroui/toast": "2.0.22",
    "@lottiefiles/dotlottie-react": "0.19.6",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@next/third-parties": "16.2.10",
    "@openrouter/ai-sdk-provider": "2.10.0",
    "@prisma/adapter-neon": "7.8.0",
    "@prisma/client": "7.8.0",
    "@sanity/client": "7.23.0",
    "@sanity/icons": "4.1.0",
    "@sanity/image-url": "2.1.1",
    "@sanity/ui": "3.3.0",
    "@sanity/vision": "6.3.0",
    "ai": "7.0.11",
    "better-auth": "1.6.23",
    "clsx": "2.1.1",
    "fuse.js": "7.4.2",
    "mcp-handler": "1.1.0",
    "next": "16.2.10",
    "next-intl": "4.13.1",
    "next-sanity": "13.1.1",
    "nuqs": "2.9.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "5.7.0",
    "sanity": "6.3.0",
    "server-only": "0.0.1",
    "styled-components": "6.4.3",
    "swiper": "14.0.1",
    "tailwind-merge": "3.6.0",
    "typescript": "6.0.3",
    "use-debounce": "10.1.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/node": "24.12.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "17.4.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "10.1.8",
    "postcss": "8.5.16",
    "postcss-load-config": "6.0.1",
    "prettier": "3.9.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "prisma": "7.8.0",
    "react-doctor": "0.6.0",
    "tailwindcss": "4.3.2"
  }
}
